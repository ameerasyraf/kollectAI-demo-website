# Browser-facing URLs
VITE_APP_NAME="Kollect AI Demo"

# Server
PORT=8787
NODE_ENV=development

# KollectGPT proxy
# The browser never sees this key. The React app calls /api/kollectgpt/chat.
KOLLECTGPT_API_URL=
KOLLECTGPT_API_KEY=
# Optional. Defaults to /api/chat when KOLLECTGPT_API_URL is just the gateway origin.
# Set this to /api/chat/stream if your upstream exposes the streaming endpoint directly.
KOLLECTGPT_CHAT_PATH=
KOLLECTGPT_TIMEOUT_MS=180000

# VoiceBot proxy
# Supported modes: public_widget, public_demo_voice, generic
VOICEBOT_INTEGRATION_MODE=public_widget
# In public_widget mode this should point to .../api/public/widget
# In public_demo_voice mode this should point to the backend API root, e.g. .../api
VOICEBOT_API_URL=
# Only used in generic mode. Leave blank for public_widget mode.
VOICEBOT_API_KEY=
VOICEBOT_AGENT_ID=
VOICEBOT_DEMO_KEY=
VOICEBOT_DEMO_ENVIRONMENT=development
VOICEBOT_DEMO_ORIGIN=http://localhost:5177
VOICEBOT_WIDGET_KEY=
VOICEBOT_WIDGET_ENVIRONMENT=development
VOICEBOT_WIDGET_ORIGIN=http://localhost:5177
VOICEBOT_WIDGET_FRAME_URL=
VOICEBOT_PAGE_URL=http://localhost:5177/voicebot
VOICEBOT_MODE_PREFERENCE=voice

# Optional: comma-separated origins when deploying the frontend separately.
ALLOWED_ORIGINS=http://localhost:5177,http://127.0.0.1:5177
