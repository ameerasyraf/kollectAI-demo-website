{
  "name": "kollect-demo-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5177",
    "dev:server": "node --watch server/index.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "demo:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-demo.ps1",
    "demo:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-demo.ps1",
    "demo:restart": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/restart-demo.ps1",
    "voicebot:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-voicebot.ps1",
    "voicebot:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-voicebot.ps1",
    "all:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-all.ps1",
    "all:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-all.ps1",
    "all:restart": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/restart-all.ps1",
    "smoke": "node scripts/smoke-demo.mjs",
    "build": "vite build",
    "start": "node server/index.js",
    "preview": "vite preview --host 0.0.0.0 --port 4177"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "vite": "^8.0.8"
  }
}
